model DailyTaskAllocation {
  id              String   @id @default(uuid())
  resourceId      String
  projectId       String?
  milestoneId     String?
  taskId          String?
  desc            String?
  description     String?
  estimatedHours  Float?
  actualHours     Float?
  date            DateTime
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
