model Task {
  id             String     @id @default(uuid())
  title          String
  description    String
  estimatedHours Float?
  actualHours    Float
  taskStatus     TaskStatus
  taskType       TaskType   @default(FEATURE)
  bugSheet       String?
  bugNumber      String?
  assignedTo     Resource[] @relation("TaskToResource")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Foreign key
  milestoneId String

  // Relation
  milestone Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  parentTaskId String?
  parentTask   Task?   @relation("TaskToSubTask", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subTasks     Task[]  @relation("TaskToSubTask")

  comments TaskComment[]
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum TaskType {
  FEATURE
  BUG
}
