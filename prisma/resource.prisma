model Resource {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  role      Role
  isActive  Boolean?  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  MANAGER
  DEV
  TESTER
  DESIGNER
  HR
  BIZ_DEV
}
