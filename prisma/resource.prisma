model Resource {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  role      Role
  isActive  Boolean
  leads     Lead[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  MANAGER
  DEV
  TESTER
  DESIGNER
  HR
  BDE
}
