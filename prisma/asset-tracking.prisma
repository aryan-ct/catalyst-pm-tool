model AssetTracking {
  id                   String           @id @default(uuid())
  name                 String
  product              String
  productName          String
  serialNumber         String?          @unique
  status               AssetStatus      @default(AVAILABLE)
  productConfiguration String?
  laptopPin            String?
  laptopPassword       String?
  assetPrice           Decimal?
  dateOfAllocation     DateTime?
  loans                String?
  otherAccessories     String?
  comments             String?
  workingCondition     WorkingCondition @default(GOOD)
  previousUser         String?
  allocatedTo          String?
  allocatedToName      String?
  addedByResourceId    String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  allocationHistory    AssetAllocationHistory[]
  repairHistory        AssetRepairHistory[]
}

model AssetAllocationHistory {
  id               String           @id @default(uuid())
  assetId          String
  asset            AssetTracking    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  allocatedTo      String
  allocatedToName  String
  allocatedAt      DateTime         @default(now())
  returnedAt       DateTime?
  comments         String?
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  IN_REPAIR
  RETIRED
}

enum WorkingCondition {
  GOOD
  FAIR
  POOR
  DAMAGED
}

model AssetRepairHistory {
  id               String           @id @default(uuid())
  assetId          String
  asset            AssetTracking    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  issueDescription String
  reportedAt       DateTime         @default(now())
  sentForRepairAt  DateTime?
  expectedReturnAt DateTime?
  repairedAt       DateTime?
  repairCost       Decimal?
  vendorName       String?
  status           RepairStatus     @default(PENDING)
  comments         String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

enum RepairStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
